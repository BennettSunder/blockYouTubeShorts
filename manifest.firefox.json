{
  "manifest_version": 2,
  "name": "Block YouTube Shorts Shelves",
  "version": "1.0.0",
  "description": "Hides Shorts shelves on YouTube.",
  "permissions": [
    "storage",
    "tabs",
    "https://www.youtube.com/*"
  ],
  "browser_action": {
    "default_title": "Shorts Shelf Blocker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
